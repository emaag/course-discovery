{
    "name": "oxfordinternational/course-discovery",
    "description": "Course Discovery plugin for WordPress.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-phpunit/wp-phpunit": "^7.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "OxfordInternational\\CourseDiscovery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OxfordInternational\\CourseDiscovery\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit -c phpunit-integration.xml.dist"
    }
}
